generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  name              String
  role              String   @default("citizen")
  emailVerified     DateTime?          // null = not verified
  verificationToken String?  @unique   // token sent to user's email
  resetToken        String?  @unique   // for password reset (used later)
  resetTokenExpiry  DateTime?          // for password reset
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  issues            Issue[]
}

model Issue {
  id        String   @id @default(cuid())
  title     String
  category  String
  location  String
  date      String
  status    String   @default("Open")
  priority  String   @default("Medium")
  lat       Float?
  lng       Float?
  image     String?   // Cloudinary URL
  logs      Json     @default("[]")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}