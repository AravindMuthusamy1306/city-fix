generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Issue {
  id        String   @id @default(cuid())
  title     String
  category  String
  location  String
  date      String
  status    String   @default("Open")
  priority  String   @default("Medium")
  lat       Float?
  lng       Float?
  image     String? // base64
  logs      Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
